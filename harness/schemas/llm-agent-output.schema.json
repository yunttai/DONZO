{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://donzo.local/schemas/llm-agent-output.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_output_id",
    "agent",
    "subject_id",
    "subject_type",
    "verdict",
    "confidence",
    "summary",
    "evidence",
    "recommended_actions",
    "blocked_actions"
  ],
  "properties": {
    "agent_output_id": {"type": "string", "minLength": 1},
    "agent": {
      "type": "string",
      "enum": [
        "api_modeler",
        "invariant_reviewer",
        "test_planner",
        "oracle_reviewer",
        "report_reviewer"
      ]
    },
    "subject_id": {"type": "string", "minLength": 1},
    "subject_type": {"type": "string", "minLength": 1},
    "verdict": {
      "type": "string",
      "enum": [
        "accept",
        "needs_more_evidence",
        "likely_false_positive",
        "out_of_scope_or_not_allowed"
      ]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "summary": {"type": "string", "minLength": 1},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "recommended_actions": {"type": "array", "items": {"type": "string"}},
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    }
  }
}
