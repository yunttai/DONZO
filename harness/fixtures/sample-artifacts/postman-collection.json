{
  "info": {
    "name": "DONZO sample collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.example.com"
    }
  ],
  "item": [
    {
      "name": "List courses",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/lms/api/courses?student_id=1"
      }
    },
    {
      "name": "GraphQL",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/graphql"
      }
    }
  ]
}
